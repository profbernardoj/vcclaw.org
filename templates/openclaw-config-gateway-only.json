{
  "$schema": "Simplest Everclaw config — [REDACTED] API Gateway only (no local proxy needed).",
  "_instructions": [
    "This is the EASIEST way to get started with Everclaw.",
    "Uses the [REDACTED] API Gateway (api.mor.org) — no local proxy-router needed.",
    "Just get a free API key from https://app.mor.org and paste it below.",
    "Works on any OS (macOS, Linux, Windows WSL2, Raspberry Pi).",
    "IMPORTANT: 'everclaw' is a SKILL, NOT a provider.",
    "NEVER use 'everclaw/' as a model prefix."
  ],
  "[REDACTED]": {
    "controlUi": {
      "_comment": "Required when [REDACTED] binds to non-loopback (0.0.0.0 / lan). Without this, [REDACTED] crashes on startup. dangerouslyDisableDeviceAuth and allowInsecureAuth are needed for HTTP access from non-localhost IPs (e.g. Docker container IP).",
      "enabled": true,
      "dangerouslyDisableDeviceAuth": true,
      "allowInsecureAuth": true,
      "allowedOrigins": [
        "http://localhost:18789",
        "http://127.0.0.1:18789",
        "http://[::1]:18789"
      ],
      "dangerouslyAllowHostHeaderOriginFallback": true
    }
  },
  "models": {
    "mode": "merge",
    "providers": {
      "mor-[REDACTED]": {
        "baseUrl": "https://api.mor.org/api/v1",
        "apiKey": "YOUR_MOR_GATEWAY_API_KEY",
        "api": "openai-completions",
        "models": [
          {
            "id": "glm-5.1",
            "name": "GLM-5.1 (via [REDACTED] Gateway)",
            "reasoning": false
          },
          {
            "id": "glm-5",
            "name": "GLM-5 (via [REDACTED] Gateway)",
            "reasoning": false,
            "input": [
              "text"
            ],
            "cost": {
              "input": 0,
              "output": 0,
              "cacheRead": 0,
              "cacheWrite": 0
            },
            "contextWindow": 131072,
            "maxTokens": 8192
          },
          {
            "id": "kimi-k2.5",
            "name": "Kimi K2.5 (via [REDACTED] Gateway)",
            "reasoning": false,
            "input": [
              "text"
            ],
            "cost": {
              "input": 0,
              "output": 0,
              "cacheRead": 0,
              "cacheWrite": 0
            },
            "contextWindow": 131072,
            "maxTokens": 8192
          },
          {
            "id": "glm-4.7-flash",
            "name": "GLM 4.7 Flash (via [REDACTED] Gateway)",
            "reasoning": false,
            "input": [
              "text"
            ],
            "cost": {
              "input": 0,
              "output": 0,
              "cacheRead": 0,
              "cacheWrite": 0
            },
            "contextWindow": 131072,
            "maxTokens": 8192
          }
        ]
      }
    }
  },
  "tools": {
    "exec": {
      "_comment": "Set ask to 'off' to disable exec approval prompts. Use 'on-miss' for allowlist-based approval. Money operations are gated at the application layer (everclaw-wallet.mjs), not the exec layer.",
      "ask": "off",
      "strictInlineEval": false
    }
  },
  "agents": {
    "defaults": {
      "timeoutSeconds": 300,
      "model": {
        "_comment": "GLM-5.1 via [REDACTED] Gateway as primary. Add your paid provider (venice, openai, etc.) as fallback if desired.",
        "primary": "mor-[REDACTED]/glm-5.1",
        "fallbacks": [
          "mor-[REDACTED]/glm-5",
          "mor-[REDACTED]/kimi-k2.5"
        ]
      },
      "models": {
        "mor-[REDACTED]/glm-5.1": {
          "streaming": true
        },
        "mor-[REDACTED]/glm-5": {
          "streaming": true
        },
        "mor-[REDACTED]/kimi-k2.5": {
          "streaming": true
        },
        "mor-[REDACTED]/glm-4.7-flash": {
          "streaming": true
        }
      }
    }
  }
}
