      "ask": "off",
      "strictInlineEval": false
    }
  },
  "agents": {
    "defaults": {
      "timeoutSeconds": 300,
      "model": {
        "_comment": "Set your primary to a [REDACTED] model. Add your paid provider as fallback.",
        "primary": "mor-[REDACTED]/glm-5.1",
        "fallbacks": [
          "mor-[REDACTED]/glm-5",
          "mor-[REDACTED]/kimi-k2.5",
          "morpheus/glm-5",
