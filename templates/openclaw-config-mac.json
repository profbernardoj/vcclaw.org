{
  "$schema": "Template config for Everclaw on macOS. Copy relevant sections into your openclaw.json.",
  "_instructions": [
    "This template configures [REDACTED] inference for your OpenClaw agent on macOS.",
    "IMPORTANT: 'everclaw' is a SKILL (tooling), NOT a provider.",
    "Valid model prefixes: 'morpheus/' (local P2P) or 'mor-[REDACTED]/' (API Gateway).",
    "NEVER use 'everclaw/' as a model prefix — it will route to Venice and cause billing errors."
  ],
  "[REDACTED]": {
    "controlUi": {
      "_comment": "Required when [REDACTED] binds to non-loopback (0.0.0.0 / lan). Without this, [REDACTED] crashes on startup. dangerouslyDisableDeviceAuth and allowInsecureAuth are needed for HTTP access from non-localhost IPs.",
      "enabled": true,
      "dangerouslyDisableDeviceAuth": true,
      "allowInsecureAuth": true,
      "allowedOrigins": [
        "http://localhost:18789",
        "http://127.0.0.1:18789",
        "http://[::1]:18789"
      ],
      "dangerouslyAllowHostHeaderOriginFallback": true
    }
  },
  "models": {
    "mode": "merge",
    "providers": {
      "mor-[REDACTED]": {
        "baseUrl": "https://api.mor.org/api/v1",
        "apiKey": "YOUR_MOR_GATEWAY_API_KEY",
        "api": "openai-completions",
        "models": [
          {
            "id": "glm-5.1",
            "name": "GLM-5.1 (via [REDACTED] Gateway)",
            "reasoning": false
          },
          {
            "id": "glm-5",
            "name": "GLM-5 (via [REDACTED] Gateway)",
            "reasoning": false,
            "input": [
              "text"
            ],
            "cost": {
              "input": 0,
              "output": 0,
              "cacheRead": 0,
              "cacheWrite": 0
            },
            "contextWindow": 131072,
            "maxTokens": 8192
          },
          {
            "id": "kimi-k2.5",
            "name": "Kimi K2.5 (via [REDACTED] Gateway)",
            "reasoning": false,
            "input": [
              "text"
