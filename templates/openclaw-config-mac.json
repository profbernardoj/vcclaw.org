{
  "$schema": "Template config for Everclaw on macOS. Copy relevant sections into your openclaw.json.",
  "_instructions": [
    "This template configures Morpheus inference for your OpenClaw agent on macOS.",
    "IMPORTANT: 'everclaw' is a SKILL (tooling), NOT a provider.",
    "Valid model prefixes: 'morpheus/' (local P2P) or 'mor-gateway/' (API Gateway).",
    "NEVER use 'everclaw/' as a model prefix — it will route to Venice and cause billing errors."
  ],
  "gateway": {
    "controlUi": {
      "_comment": "Required when gateway binds to non-loopback (0.0.0.0 / lan). Without this, gateway crashes on startup.",
      "enabled": true,
      "allowedOrigins": [
        "http://localhost:18789",
        "http://127.0.0.1:18789",
        "http://[::1]:18789"
      ],
      "dangerouslyAllowHostHeaderOriginFallback": true
    }
  },
  "models": {
    "mode": "merge",
    "providers": {
      "mor-gateway": {
        "baseUrl": "https://api.mor.org/api/v1",
        "apiKey": "YOUR_MOR_GATEWAY_API_KEY",
        "api": "openai-completions",
        "models": [
          {
            "id": "glm-5",
            "name": "GLM-5 (via Morpheus Gateway)",
            "reasoning": false,
            "input": ["text"],
            "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 },
            "contextWindow": 131072,
            "maxTokens": 8192
          },
          {
            "id": "kimi-k2.5",
            "name": "Kimi K2.5 (via Morpheus Gateway)",
            "reasoning": false,
            "input": ["text"],
            "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 },
            "contextWindow": 131072,
            "maxTokens": 8192
          },
          {
            "id": "glm-4.7-flash",
            "name": "GLM 4.7 Flash (via Morpheus Gateway)",
            "reasoning": false,
            "input": ["text"],
            "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 },
            "contextWindow": 131072,
            "maxTokens": 8192
          }
        ]
      },
      "ollama": {
        "_comment": "Local Ollama inference fallback. Run 'bash scripts/setup-ollama.sh --apply' to auto-detect hardware and install the optimal model, or configure manually.",
        "baseUrl": "http://127.0.0.1:11434/v1",
        "api": "ollama",
        "models": [
          {
            "id": "qwen3.5:9b",
            "_note": "Auto-selected by setup-ollama.sh based on your hardware. Replace with your actual model.",
            "name": "Qwen3.5 9B (Local Ollama)",
            "reasoning": false,
            "input": ["text"],
            "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 },
            "contextWindow": 32768,
            "maxTokens": 8192
          }
        ]
      },
      "morpheus": {
        "baseUrl": "http://127.0.0.1:8083/v1",
        "apiKey": "morpheus-local",
        "api": "openai-completions",
        "models": [
          {
            "id": "glm-5",
            "name": "GLM-5 (via Morpheus P2P)",
            "reasoning": false,
            "input": ["text"],
            "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 },
            "contextWindow": 131072,
            "maxTokens": 8192
          },
          {
            "id": "kimi-k2.5",
            "name": "Kimi K2.5 (via Morpheus P2P)",
            "reasoning": false,
            "input": ["text"],
            "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 },
            "contextWindow": 131072,
            "maxTokens": 8192
          },
          {
            "id": "glm-4.7-flash",
            "name": "GLM 4.7 Flash (via Morpheus P2P)",
            "reasoning": false,
            "input": ["text"],
            "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 },
            "contextWindow": 131072,
            "maxTokens": 8192
          },
          {
            "id": "kimi-k2-thinking",
            "name": "Kimi K2 Thinking (via Morpheus P2P)",
            "reasoning": false,
            "input": ["text"],
            "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 },
            "contextWindow": 131072,
            "maxTokens": 8192
          }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "_comment": "Set your primary to a Morpheus model. Add your paid provider as fallback.",
        "primary": "mor-gateway/glm-5",
        "fallbacks": [
          "mor-gateway/kimi-k2.5",
          "morpheus/glm-5",
          "morpheus/kimi-k2.5",
          "ollama/qwen3.5:9b"
        ]
      }
    }
  }
}
